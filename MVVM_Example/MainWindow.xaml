<Window x:Class="MVVM_Example.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MVVM_Example.ViewModels"
        mc:Ignorable="d"
        Title="Task Manager - MVVM Demo" 
        Height="700" 
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.DataContext>
        <vm:TaskViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Стиль для карточки задачи -->
        <Style x:Key="TaskCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3A3A5A"/>
        </Style>

        <!-- Конвертер для цвета завершенных задач -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <!-- Фоновое изображение машины -->
        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/Resources/car_background.jpg" 
                        Stretch="UniformToFill" 
                        Opacity="0.3"/>
        </Grid.Background>

        <!-- Основной контент -->
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок с логотипом -->
            <Border Grid.Row="0" 
                    Background="{StaticResource CardBrush}" 
                    CornerRadius="15" 
                    Padding="25"
                    Margin="0,0,0,20"
                    BorderBrush="{StaticResource PrimaryBrush}"
                    BorderThickness="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Логотип -->
                    <Border Grid.Column="0" 
                            Width="80" 
                            Height="80" 
                            Background="{StaticResource PrimaryBrush}" 
                            CornerRadius="20"
                            VerticalAlignment="Center">
                        <Grid>
                            <TextBlock Text="🚗" 
                                       FontSize="40" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Текст заголовка -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                        <TextBlock Text="TASK MANAGER" 
                                   FontSize="32" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="Organize your day, drive your success" 
                                   FontSize="14" 
                                   Foreground="#AAAAAA"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Панель добавления задачи -->
            <Border Grid.Row="0" 
                    VerticalAlignment="Bottom" 
                    Margin="0,100,0,0"
                    Background="{StaticResource CardBrush}" 
                    CornerRadius="12" 
                    Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" 
                             Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"
                             Hint="Название задачи..."
                             Margin="0,0,10,0"/>

                    <TextBox Grid.Column="1" 
                             Text="{Binding NewTaskDescription, UpdateSourceTrigger=PropertyChanged}"
                             Hint="Описание..."
                             Margin="0,0,10,0"/>

                    <Button Grid.Column="2" 
                            Content="➕ Добавить" 
                            Command="{Binding AddTaskCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="140"/>
                </Grid>
            </Border>

            <!-- Список задач -->
            <Border Grid.Row="1" 
                    Background="{StaticResource CardBrush}" 
                    CornerRadius="15" 
                    Padding="20"
                    Margin="0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок списка -->
                    <TextBlock Grid.Row="0" 
                               Text="📋 Ваши задачи" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               Foreground="White"
                               Margin="0,0,0,15"/>

                    <!-- Список -->
                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Tasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource TaskCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Checkbox -->
                                            <CheckBox Grid.Column="0" 
                                                      IsChecked="{Binding IsCompleted}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,15,0"/>

                                            <!-- Информация о задаче -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" 
                                                           FontSize="18" 
                                                           FontWeight="Bold"
                                                           Foreground="White">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                    <Setter Property="Foreground" Value="#888888"/>
                                                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Description}" 
                                                           FontSize="13" 
                                                           Foreground="#CCCCCC"
                                                           Margin="0,5,0,0"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock FontSize="11" 
                                                           Foreground="#666666"
                                                           Margin="0,8,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding CreatedAt, StringFormat='Создано: {0:dd.MM.yyyy HH:mm}'}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                    <Setter Property="Text" Value="{Binding CompletedAt, StringFormat='Завершено: {0:dd.MM.yyyy HH:mm}'}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Кнопки действий -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <Button Content="🗑️" 
                                                        Command="{Binding DataContext.RemoveTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource DangerButtonStyle}"
                                                        Width="40"
                                                        Margin="5,0,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Панель действий -->
            <Border Grid.Row="2" 
                    Background="{StaticResource CardBrush}" 
                    CornerRadius="12" 
                    Padding="20"
                    Margin="0,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                               VerticalAlignment="Center"
                               Foreground="#AAAAAA">
                        <Run Text="Всего задач: "/>
                        <Run Text="{Binding Tasks.Count}" FontWeight="Bold" Foreground="White"/>
                        <Run Text=" | Выполнено: "/>
                        <Run Text="{Binding Tasks, Converter={StaticResource ResourceKey={x:Null}}, StringFormat={}{0}}" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                    </TextBlock>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="🧹 Очистить выполненные" 
                                Command="{Binding ClearCompletedCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,10,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
